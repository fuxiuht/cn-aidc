<% var pageTitle = '仪表盘' %>
<%- include('header') %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-number"><%= totalArticles %></div>
    <div class="stat-label">文章总数</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= publishedArticles %></div>
    <div class="stat-label">已发布</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= totalArticles - publishedArticles %></div>
    <div class="stat-label">草稿</div>
  </div>
  <div class="stat-card">
    <div class="stat-number"><%= totalCategories %></div>
    <div class="stat-label">分类数</div>
  </div>
</div>

<div class="panel">
  <div class="panel-header">
    <h3>最近文章</h3>
    <a href="/admin/articles/new" class="btn btn-primary btn-sm">+ 新建文章</a>
  </div>
  <table class="data-table">
    <thead><tr><th>标题</th><th>状态</th><th>创建时间</th></tr></thead>
    <tbody>
      <% if (recentArticles.length === 0) { %>
        <tr><td colspan="3" style="text-align:center;color:#999">暂无文章</td></tr>
      <% } else { %>
        <% recentArticles.forEach(function(a) { %>
          <tr>
            <td><%= a.title %></td>
            <td><span class="badge <%= a.status %>"><%= a.status === 'published' ? '已发布' : '草稿' %></span></td>
            <td><%= (a.created_at || '').slice(0, 16) %></td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
