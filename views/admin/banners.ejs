<% var pageTitle = 'Banner管理' %>
<%- include('header') %>

<div class="panel">
  <div class="panel-header">
    <h3>Banner管理</h3>
  </div>

  <form method="POST" action="/admin/banners/save" enctype="multipart/form-data" class="inline-form" style="margin-bottom:20px">
    <input type="text" name="title" placeholder="Banner标题" required>
    <input type="text" name="link" placeholder="跳转链接（可选）">
    <input type="number" name="sort_order" placeholder="排序" value="0" style="width:80px">
    <input type="file" name="banner_image" accept="image/*" required>
    <button type="submit" class="btn btn-primary btn-sm">添加</button>
  </form>

  <table class="data-table">
    <thead>
      <tr><th>ID</th><th>预览</th><th>标题</th><th>链接</th><th>排序</th><th>状态</th><th>操作</th></tr>
    </thead>
    <tbody>
      <% if (banners.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:#999">暂无Banner</td></tr>
      <% } else { %>
        <% banners.forEach(function(b) { %>
          <tr>
            <td><%= b.id %></td>
            <td><img src="<%= b.image %>" style="width:120px;height:60px;object-fit:cover;border-radius:4px"></td>
            <td><%= b.title %></td>
            <td><%= b.link || '-' %></td>
            <td><%= b.sort_order %></td>
            <td><span class="badge <%= b.is_active ? 'published' : 'draft' %>"><%= b.is_active ? '启用' : '禁用' %></span></td>
            <td class="actions">
              <form method="POST" action="/admin/banners/toggle/<%= b.id %>" style="display:inline">
                <button type="submit" class="btn btn-sm"><%= b.is_active ? '禁用' : '启用' %></button>
              </form>
              <form method="POST" action="/admin/banners/delete/<%= b.id %>" style="display:inline" onsubmit="return confirm('确定删除？')">
                <button type="submit" class="btn btn-sm btn-danger">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
