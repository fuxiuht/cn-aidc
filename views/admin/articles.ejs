<% var pageTitle = '文章管理' %>
<%- include('header') %>

<div class="panel">
  <div class="panel-header">
    <h3>全部文章 (<%= articles.length %>)</h3>
    <a href="/admin/articles/new" class="btn btn-primary btn-sm">+ 新建文章</a>
  </div>
  <table class="data-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>标题</th>
        <th>分类</th>
        <th>状态</th>
        <th>创建时间</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (articles.length === 0) { %>
        <tr><td colspan="6" style="text-align:center;color:#999">暂无文章</td></tr>
      <% } else { %>
        <% articles.forEach(function(a) { %>
          <tr>
            <td><%= a.id %></td>
            <td><a href="/article/<%= a.id %>" target="_blank"><%= a.title %></a></td>
            <td><%= a.category_name || '-' %></td>
            <td><span class="badge <%= a.status %>"><%= a.status === 'published' ? '已发布' : '草稿' %></span></td>
            <td><%= (a.created_at || '').slice(0, 10) %></td>
            <td class="actions">
              <a href="/admin/articles/edit/<%= a.id %>" class="btn btn-sm">编辑</a>
              <form method="POST" action="/admin/articles/delete/<%= a.id %>" style="display:inline" onsubmit="return confirm('确定删除？')">
                <button type="submit" class="btn btn-sm btn-danger">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
