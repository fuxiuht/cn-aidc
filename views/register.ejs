<%- include('header') %>

<style>
.register-page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: calc(100vh - 200px);
  padding: 60px 0;
}
.register-card {
  background: #fff;
  border-radius: 24px;
  padding: 50px;
  max-width: 680px;
  margin: 0 auto;
  box-shadow: 0 20px 60px rgba(0,0,0,0.15);
}
.register-header {
  text-align: center;
  margin-bottom: 40px;
}
.register-header .event-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
  font-size: 36px;
}
.register-header h1 {
  font-size: 32px;
  color: #1a1a2e;
  margin-bottom: 8px;
  font-weight: 700;
}
.register-header .subtitle {
  color: #666;
  font-size: 16px;
  margin-bottom: 20px;
}
.event-info {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: linear-gradient(135deg, #fff5f5, #fff);
  border: 1px solid #ffdfe5;
  padding: 10px 20px;
  border-radius: 30px;
  color: #e53935;
  font-size: 14px;
  font-weight: 500;
}
.event-info .dot {
  width: 8px;
  height: 8px;
  background: #e53935;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}
.form-row { display: flex; gap: 16px; }
.form-group { margin-bottom: 24px; flex: 1; }
.form-group label {
  display: block;
  font-size: 14px;
  color: #444;
  margin-bottom: 10px;
  font-weight: 600;
}
.form-group label span { color: #e53935; margin-left: 4px; }
.form-group input {
  width: 100%;
  padding: 14px 18px;
  border: 2px solid #e8e8e8;
  border-radius: 12px;
  font-size: 15px;
  transition: all 0.3s;
}
.form-group input:focus {
  outline: none;
  border-color: #667eea;
  box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
}
.form-group input::placeholder { color: #aaa; }
.btn-register {
  width: 100%;
  padding: 16px;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border: none;
  border-radius: 12px;
  font-size: 17px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s;
  margin-top: 10px;
}
.btn-register:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
}
.alert {
  padding: 16px 20px;
  border-radius: 12px;
  margin-bottom: 24px;
  font-size: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.alert-success {
  background: #e8f5e9;
  color: #2e7d32;
  border: 1px solid #a5d6a7;
}
.alert-success::before { content: '✓'; font-weight: 700; }
.alert-error {
  background: #ffebee;
  color: #c62828;
  border: 1px solid #ffcdd2;
}
.alert-error::before { content: '!'; font-weight: 700; }
.register-footer {
  text-align: center;
  margin-top: 30px;
  padding-top: 24px;
  border-top: 1px solid #f0f0f0;
  color: #888;
  font-size: 13px;
}
.register-footer a { color: #667eea; text-decoration: none; }
@media (max-width: 600px) {
  .register-card { padding: 30px 20px; margin: 0 16px; }
  .form-row { flex-direction: column; gap: 0; }
  .register-header h1 { font-size: 24px; }
}
</style>

<div class="register-page">
  <div class="container">
    <div class="register-card">
      <div class="register-header">
        <div class="event-icon">🎓</div>
        <h1>嘉宾报名</h1>
        <p class="subtitle">2026年文化馆服务宣传周 · 市民夜校解压局</p>
        <div class="event-info">
          <span class="dot"></span>
          5月18-24日 | 5月19日免费体验课
        </div>
      </div>

      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/register">
        <input type="hidden" name="event_name" value="爱上文化馆2026">

        <div class="form-row">
          <div class="form-group">
            <label>姓名 <span>*</span></label>
            <input type="text" name="name" required placeholder="请输入您的姓名">
          </div>
          <div class="form-group">
            <label>公司/单位</label>
            <input type="text" name="company" placeholder="请输入公司或单位名称">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>职位/头衔</label>
            <input type="text" name="title" placeholder="如：工程师、总监等">
          </div>
          <div class="form-group">
            <label>手机号</label>
            <input type="tel" name="phone" placeholder="请输入手机号码">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>邮箱</label>
            <input type="email" name="email" placeholder="请输入邮箱地址">
          </div>
          <div class="form-group">
            <label>微信号</label>
            <input type="text" name="wechat" placeholder="请输入微信号">
          </div>
        </div>

        <button type="submit" class="btn-register">立即报名参加</button>
      </form>

      <div class="register-footer">
        <a href="/">← 返回首页</a>
      </div>
    </div>
  </div>
</div>

<%- include('footer') %>